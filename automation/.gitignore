# Runtime artifacts (regenerated by pipeline runs)
logs/*
!logs/.gitkeep

cache/*
!cache/.gitkeep

reports/*
!reports/.gitkeep

raw_documents/*
!raw_documents/.gitkeep

queue/pending/*
!queue/pending/.gitkeep

queue/approved/*
!queue/approved/.gitkeep

queue/rejected/*
!queue/rejected/.gitkeep

review/*
!review/.gitkeep
